<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>高次脳機能評価 判定ツール</title>
    <style>
        :root { --primary: #2c3e50; --accent: #3498db; --bg: #f8f9fa; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.6; color: #333; max-width: 900px; margin: 0 auto; padding: 20px; background-color: var(--bg); }
        .card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 20px; }
        h1, h2 { color: var(--primary); border-bottom: 2px solid var(--accent); padding-bottom: 8px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .input-item { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9em; }
        input { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; }
        button { background: var(--accent); color: white; border: none; padding: 15px 30px; border-radius: 8px; cursor: pointer; font-size: 1.1em; width: 100%; transition: 0.3s; }
        button:hover { background: #2980b9; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; background: white; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background: #f2f2f2; }
        .status-low { background: #ffebee; color: #c62828; font-weight: bold; }
        .status-border { background: #fff3e0; color: #ef6c00; font-weight: bold; }
        .status-normal { background: #e8f5e9; color: #2e7d32; }
    </style>
</head>
<body>

    <h1>高次脳機能評価 判定ツール</h1>

    <div class="card">
        <h2>1. 基本情報</h2>
        <div class="input-item">
            <label>年齢 (18-90歳) ※必須</label>
            <input type="number" id="age" placeholder="例: 65">
        </div>
    </div>

    <div class="grid">
        <div class="card">
            <h2>WAIS-IV (合成得点)</h2>
            <div class="input-item"><label>FSIQ (全検査IQ)</label><input type="number" id="wais_fsiq"></div>
            <div class="input-item"><label>VCI (言語理解)</label><input type="number" id="wais_vci"></div>
            <div class="input-item"><label>PRI (知覚推理)</label><input type="number" id="wais_pri"></div>
            <div class="input-item"><label>WMI (ワーキングメモリ)</label><input type="number" id="wais_wmi"></div>
            <div class="input-item"><label>PSI (処理速度)</label><input type="number" id="wais_psi"></div>
        </div>

        <div class="card">
            <h2>CAT (標準注意検査法)</h2>
            <div class="input-item"><label>TMT-A (秒)</label><input type="number" id="cat_tmt_a"></div>
            <div class="input-item"><label>TMT-B (秒)</label><input type="number" id="cat_tmt_b"></div>
            <div class="input-item"><label>PASAT 3.0s (正答数)</label><input type="number" id="cat_pasat3"></div>
            <div class="input-item"><label>PASAT 2.0s (正答数)</label><input type="number" id="cat_pasat2"></div>
        </div>
    </div>

    <button onclick="diagnose()">結果を判定・意味付けする</button>

    <div id="resultArea" style="display:none;" class="card">
        <h2>判定結果一覧</h2>
        <table>
            <thead>
                <tr>
                    <th>評価項目</th>
                    <th>入力値</th>
                    <th>判定</th>
                    <th>臨床的意味付け</th>
                </tr>
            </thead>
            <tbody id="resultBody"></tbody>
        </table>
    </div>

<script>
// CAT基準値データ (マニュアルに基づいた年代別近似値)
const CAT_DATA = [
    { range: [18, 39], tmta: 45, tmtb: 90, pasat3: 40, pasat2: 35 },
    { range: [40, 59], tmta: 60, tmtb: 130, pasat3: 35, pasat2: 25 },
    { range: [60, 74], tmta: 85, tmtb: 180, pasat3: 25, pasat2: 15 },
    { range: [75, 90], tmta: 110, tmtb: 240, pasat3: 15, pasat2: 10 }
];

function getWaisInfo(score) {
    if (score >= 130) return { label: "非常に高い", class: "status-normal", desc: "上位2.2%。非常に優れた知的能力。" };
    if (score >= 120) return { label: "高い", class: "status-normal", desc: "上位9%。高い知的能力。" };
    if (score >= 110) return { label: "平均の上", class: "status-normal", desc: "平均より良好。" };
    if (score >= 90)  return { label: "平均", class: "status-normal", desc: "同年代の標準的な範囲。" };
    if (score >= 80)  return { label: "平均の下", class: "status-border", desc: "日常生活に支障はないが、慎重な対応を要する場合がある。" };
    if (score >= 70)  return { label: "低い(境界線)", class: "status-border", desc: "知的障害との境界域。サポートが必要な可能性。" };
    return { label: "非常に低い", class: "status-low", desc: "全般的な知的発達の遅れ、または著しい機能低下。" };
}

function diagnose() {
    const age = parseInt(document.getElementById('age').value);
    if (isNaN(age)) { alert("年齢を入力してください"); return; }

    const tbody = document.getElementById('resultBody');
    tbody.innerHTML = "";
    
    // WAIS判定
    const waisList = [
        { id: 'wais_fsiq', name: 'WAIS: 全検査(FSIQ)' },
        { id: 'wais_vci', name: 'WAIS: 言語理解(VCI)' },
        { id: 'wais_pri', name: 'WAIS: 知覚推理(PRI)' },
        { id: 'wais_wmi', name: 'WAIS: ワーキングメモリ(WMI)' },
        { id: 'wais_psi', name: 'WAIS: 処理速度(PSI)' }
    ];

    waisList.forEach(item => {
        const val = document.getElementById(item.id).value;
        if (val !== "") {
            const info = getWaisInfo(parseInt(val));
            addRow(item.name, val, info.label, info.desc, info.class);
        }
    });

    // CAT判定
    const catNorm = CAT_DATA.find(d => age >= d.range[0] && age <= d.range[1]) || CAT_DATA[3];
    const catInputs = [
        { id: 'cat_tmt_a', name: 'CAT: TMT-A', norm: catNorm.tmta, type: 'time', desc: '視覚探索・持続的注意' },
        { id: 'cat_tmt_b', name: 'CAT: TMT-B', norm: catNorm.tmtb, type: 'time', desc: '注意の切り替え・分配' },
        { id: 'cat_pasat3', name: 'CAT: PASAT 3s', norm: catNorm.pasat3, type: 'score', desc: '計算を伴う持続的注意' },
        { id: 'cat_pasat2', name: 'CAT: PASAT 2s', norm: catNorm.pasat2, type: 'score', desc: 'より高負荷な注意・処理速度' }
    ];

    catInputs.forEach(item => {
        const val = parseInt(document.getElementById(item.id).value);
        if (!isNaN(val)) {
            let isLow = item.type === 'time' ? val > item.norm : val < item.norm;
            let label = isLow ? "低下の疑い" : "年齢相応";
            let cls = isLow ? "status-low" : "status-normal";
            addRow(item.name, val + (item.type === 'time' ? "秒" : "点"), label, item.desc, cls);
        }
    });

    document.getElementById('resultArea').style.display = "block";
}

function addRow(name, val, label, desc, cls) {
    const row = `<tr><td>${name}</td><td>${val}</td><td class="${cls}">${label}</td><td>${desc}</td></tr>`;
    document.getElementById('resultBody').innerHTML += row;
}
</script>
</body>
</html>
